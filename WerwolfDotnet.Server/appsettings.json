{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "WerwolfDotnet.GameContext": "Trace"
    }
  },
  "AllowedHosts": "*",
  "GameLobby": {
    "AllowViewAll": false,
    "PlayerNameForbiddenWords": ["Werwolf", "Dorfbewohner", "Bürgermeister"]
  },
  "Game": {
    "DefaultOptions": {
      "AmountOfRoles": {
        "-1": 1,
        "2": 1,
        "4": 1
      },
      "MayorDecidesNextMayor": true,
      "RevealRoleForCauses": [-1]
    }
  }
}
