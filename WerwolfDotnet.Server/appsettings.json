{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient.LogicalHandler": "Debug",
      "System.Net.Http.HttpClient.ClientHandler": "Debug",
      "WerwolfDotnet.GameContext": "Trace"
    }
  },
  "AllowedHosts": "*",
  "Cleanup": {
    "Intervall": "00:10:00",
    "AfterInactivity": "12:00:00",
    "AfterEmptySession": "00:30:00"
  },
  "GameLobby": {
    "AllowViewAll": false,
    "PlayerNameForbiddenWords": ["Amor", "Bärenführer", "Heiler", "Beschützer", "Jäger", "Seher", "Seherlehrling", "Brüder", "Schwestern", "Urwolf", "Dorfmatratze", "Dorfbewohner", "Werwolf", "Weißerwolf", "Bürgermeister"],
    "PlayerNameForbiddenWordsLists": [
      "https://raw.githubusercontent.com/LDNOOBW/List-of-Dirty-Naughty-Obscene-and-Otherwise-Bad-Words/refs/heads/master/de",
      "https://raw.githubusercontent.com/LDNOOBW/List-of-Dirty-Naughty-Obscene-and-Otherwise-Bad-Words/refs/heads/master/en"
    ]
  },
  "Game": {
    "DefaultOptions": {
      "AmountOfRoles": {
        "-1": 1,     // Werwolf
        "2": 1,     // Seer
        "4": 1     // Witch
      },
      "SeerSeesRole": true,
      "MayorDecidesNextMayor": true,
      "RevealRoleForCauses": []
    }
  }
}
